---
import Analyzer from '../components/Analyzer.tsx';
import '../styles/global.css'; // ADICIONE ESTA LINHA AQUI!
---

<html lang="pt-br">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<title>Resume Score AI- Otimizador ATS</title>
		
		<meta name="description" content="Analise seu currículo com IA e descubra como passar nos sistemas de triagem (ATS)." />

		<meta property="og:type" content="website" />
		<meta property="og:url" content="https://resume-score-ten.vercel.app/" />
		<meta property="og:title" content="Resume Score AI - Seu currículo nota 10" />
		<meta property="og:description" content="Analise a compatibilidade do seu currículo com vagas reais usando a inteligência da Llama-3." />
		<meta property="og:image" content="https://resume-score-ten.vercel.app/og-image.png" />

		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content="https://resume-score-ten.vercel.app/" />
		<meta property="twitter:title" content="Resume Score AI" />
		<meta property="twitter:description" content="Analise seu currículo com IA." />
		<meta property="twitter:image" content="https://resume-score-ten.vercel.app/og-image.png" />
	</head>
	<body class="bg-gray-100 min-h-screen py-10">
		<main class="container mx-auto px-4">
			<h1 class="text-4xl font-extrabold text-center text-gray-900 mb-10">
				Otimize seu currículo para <span class="text-blue-600">vencer o ATS</span>
			</h1>
			
			{/* Componente React com hidratacão client:load */}
			<Analyzer client:load />
		</main>
	</body>
</html>
